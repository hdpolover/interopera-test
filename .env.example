# Host port mappings — override if the defaults conflict with local services.
# Copy this file to .env and edit before running: docker compose up --build

# Postgres host port (container always listens on 5432 internally)
POSTGRES_HOST_PORT=5432

# Neo4j Bolt port (container always listens on 7687 internally)
NEO4J_BOLT_PORT=7687

# Neo4j HTTP port for the browser UI at http://localhost:<port>
NEO4J_HTTP_PORT=7474

# Optional: Anthropic API key for live narrative generation.
# If absent (or empty), the narrative step falls back to a deterministic stub —
# all 13 figures and the firewall check still pass without a key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the LLM model used for narrative generation.
# Default is claude-haiku-4-5-20251001. Change here if the model is deprecated
# or you want to use a different tier without touching source code.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Connection details used by the app container (do not change unless running
# outside Compose — the compose service names are the DNS hostnames).
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
POSTGRES_DSN=postgresql://interopera:interopera@postgres:5432/interopera
